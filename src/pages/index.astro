---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function getSlug(id: string) {
    return id.replace(/\.md$/, '');
}

const allPosts = await getCollection('blog');
const latestPosts = allPosts
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 3);

function formatDate(date: Date) {
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
}
---

<BaseLayout
    title="Alina — Marketing & Social Media at Piwi.AI"
    description="Marketing and social media insights for small businesses. AI-powered strategies, content tips, and real-world advice from Alina at Piwi.AI."
    canonicalUrl="https://aniteialina.com/"
>
    <!-- ===== HERO ===== -->
    <section class="hero">
        <!-- Author card: left -->
        <div class="home-author-card">
            <img src="/profile.png" alt="Alina" class="home-author-avatar" />
            <h1 class="home-author-name">Alina Anitei</h1>
            <p class="home-author-role">Marketing &amp; Growth at <a href="https://piwi.ai" target="_blank" rel="noreferrer">Piwi.AI</a></p>
            <p class="home-author-bio">Helping small businesses grow with smart content strategies and AI-powered marketing tools.</p>
            <div class="home-author-links">
                <a href="https://www.linkedin.com/in/alina-anitei/" class="home-author-social" target="_blank" rel="noreferrer" aria-label="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="https://github.com/AniteiAlina" class="home-author-social" target="_blank" rel="noreferrer" aria-label="GitHub">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                </a>
                <a href="https://piwi.ai" class="home-author-social" target="_blank" rel="noreferrer" aria-label="Piwi.AI">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </a>
            </div>
            <a href="/about" class="home-author-more">More about me →</a>
        </div>

        <!-- CTA: right -->
        <div class="hero-cta">
            <p class="hero-cta-label">For Founders &amp; Marketers</p>
            <h2 class="hero-cta-heading">Grow Smarter,<br/>Not Harder</h2>
            <p class="hero-cta-sub">I believe great marketing isn't about shouting the loudest. It's about showing up consistently, testing what works, and sharing what you learn along the way.</p>
            <a href="/blog" class="btn btn-primary hero-cta-btn">Read the Blog</a>
        </div>
    </section>

    <div class="section-divider"></div>

    <!-- ===== WHAT I DO ===== -->
    <section class="skills">
        <h2 class="section-title">What I Do</h2>
        <div class="skills-grid">
            <div class="skill-card">
                <div class="skill-icon">
                    <!-- Phone / Social icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                </div>
                <h3>Content &amp; Social Media</h3>
                <p>Creating content and building brand presence across LinkedIn, YouTube and Instagram.</p>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <!-- Cpu / AI icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
                </div>
                <h3>AI-Powered Marketing</h3>
                <p>Using AI tools to streamline content workflows and amplify marketing impact.</p>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <!-- Bar chart / Analytics icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
                </div>
                <h3>Analytics &amp; Growth</h3>
                <p>Tracking content performance to understand what actually resonates and doing more of what works.</p>
            </div>
            <div class="skill-card">
                <div class="skill-icon">
                    <!-- Rocket / Pen icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <h3>Product Hunt Launches</h3>
                <p>Planning and executing Product Hunt launches from strategy and community building to launch day.</p>
            </div>
        </div>
    </section>

    <div class="section-divider"></div>

    <!-- ===== LATEST POSTS ===== -->
    <section class="latest-posts">
        <h2 class="section-title">Latest Posts</h2>
        <div class="post-cards">
            {latestPosts.map((post) => (
                <a href={`/blog/${getSlug(post.id)}`} class="post-card">
                    <span class="post-date">{formatDate(post.data.date)}</span>
                    <h3>{post.data.title}</h3>
                    <p class="post-excerpt">{post.data.excerpt} <span class="post-read-more">Read article ➔</span></p>
                </a>
            ))}
        </div>
        <a href="/blog" class="view-all">View all posts →</a>
    </section>

</BaseLayout>

<style>
/* ===== Hero Layout ===== */
.hero {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 1.75rem 0 2rem;
    position: relative;
}

.hero::before {
    content: '';
    position: absolute;
    top: -40px;
    left: -60px;
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(255,107,107,0.07) 0%, transparent 70%);
    pointer-events: none;
    border-radius: 50%;
    z-index: 0;
}

.hero > * {
    position: relative;
    z-index: 1;
}

.home-author-card {
    flex-shrink: 0;
    width: 260px;
}

.hero-cta {
    flex: 1;
    min-width: 0;
    padding-left: 1rem;
}

.hero-cta-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.8rem;
}

.hero-cta-heading {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--text);
}

.hero-cta-sub {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 1.75rem;
}

.hero-cta-btn {
    display: inline-flex;
    font-size: 1rem;
    padding: 0.75rem 2rem;
}

.home-author-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
}

/* ===== Section Divider ===== */
.section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border) 20%, var(--border) 80%, transparent);
    margin: 0.5rem 0;
}

/* ===== Skills section title override ===== */
.skills {
    padding: 2rem 0;
}

.skills .section-title,
.latest-posts .section-title {
    position: relative;
    display: inline-block;
    padding-bottom: 0.4rem;
    margin-bottom: 1.5rem;
}

.skills .section-title::after,
.latest-posts .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 2px;
}

/* ===== Skill Cards (SVG icon styles) ===== */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

.skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.4rem;
    transition: border-color var(--transition), transform var(--transition), background var(--transition);
}

.skill-card:hover {
    background: var(--bg-card-hover);
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(255, 107, 107, 0.1);
}

.skill-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--accent-glow);
    border: 1px solid rgba(255,107,107,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 0.85rem;
    flex-shrink: 0;
}

.skill-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.45rem;
}

.skill-card p {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
}

/* ===== Latest Posts cards ===== */
.latest-posts {
    padding: 2rem 0;
}

.post-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.25rem;
}

.post-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), transform var(--transition), background var(--transition);
}

.post-card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255, 107, 107, 0.08);
}

.post-card .post-date {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    margin-bottom: 0.35rem;
    letter-spacing: 0.02em;
}

.post-card h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
}

.post-card:hover h3 {
    color: var(--accent);
}

.post-card .post-excerpt {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 0;
}

.post-read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    margin-left: 0.2rem;
    transition: color var(--transition);
}

.post-card:hover .post-read-more {
    color: var(--accent);
}

/* ===== Responsive ===== */
@media (max-width: 640px) {
    .hero {
        flex-direction: column;
    }

    .home-author-card {
        width: 100%;
    }

    .hero-cta {
        padding-left: 0;
    }

    .skills-grid {
        grid-template-columns: 1fr;
    }
}

/* ===== Author Card ===== */
.home-author {
    padding: 2rem 0;
    display: flex;
    justify-content: center;
}

.home-author-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    text-align: center;
    max-width: 420px;
    width: 100%;
}

.home-author-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    object-fit: cover;
    margin-bottom: 1rem;
}

.home-author-name {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--text);
}

.home-author-role {
    font-size: 0.88rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 0.85rem;
}

.home-author-role a {
    color: var(--accent);
}

.home-author-bio {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.1rem;
}

.home-author-links {
    display: flex;
    justify-content: center;
    gap: 0.65rem;
    margin-bottom: 1.1rem;
}

.home-author-social {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: all var(--transition);
}

.home-author-social:hover {
    color: var(--text);
    border-color: var(--accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
}

.home-author-more {
    display: inline-block;
    margin-top: 0.25rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid rgba(255,107,107,0.35);
    border-radius: 99px;
    padding: 0.35rem 1rem;
    transition: background var(--transition), border-color var(--transition);
}

.home-author-more:hover {
    background: var(--accent-glow);
    border-color: var(--accent);
}
</style>
