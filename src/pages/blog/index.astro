---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function getSlug(id: string) {
    return id.replace(/\.md$/, '');
}

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
}
---

<BaseLayout
    title="Blog — Alina"
    description="Marketing insights, content strategy tips, and AI-powered tools for small businesses. Practical advice from Alina at Piwi.AI."
    canonicalUrl="https://aniteialina.com/blog"
>
    <div class="blog-page">
        <h1>Blog</h1>
        <p class="blog-description">
            Thoughts on marketing, content strategy, and AI-powered tools for small businesses.
        </p>
        <div class="post-cards">
            {sortedPosts.map((post) => (
                <a href={`/blog/${getSlug(post.id)}`} class="post-card">
                    <span class="post-date">{formatDate(post.data.date)}</span>
                    <h2>{post.data.title}</h2>
                    <p class="post-excerpt">{post.data.excerpt} <span class="post-read-more">Read article ➔</span></p>
                </a>
            ))}
        </div>
    </div>
</BaseLayout>

<style>
.blog-page h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin-bottom: 0.5rem;
    position: relative;
    display: inline-block;
    padding-bottom: 0.4rem;
}

.blog-page h1::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 2px;
}

.blog-description {
    color: var(--text-muted);
    margin-bottom: 2rem;
}

.post-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.post-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), transform var(--transition), background var(--transition);
}

.post-card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255, 107, 107, 0.08);
}

.post-card .post-date {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
}

.post-card h2 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
}

.post-card:hover h2 {
    color: var(--accent);
}

.post-card .post-excerpt {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0;
}

.post-read-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    margin-left: 0.2rem;
    transition: color var(--transition);
}

.post-card:hover .post-read-more {
    color: var(--accent);
}
</style>
