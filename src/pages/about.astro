---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="About — Alina"
    description="Alina — Marketing & Growth at Piwi.AI. Helping small businesses grow their online presence with smart content strategies and AI-powered tools."
    canonicalUrl="https://aniteialina.com/about"
>
    <div class="about-page">
        <h1>About Me</h1>

        <div class="about-profile">
            <img src="/profile.png" alt="Alina" class="profile-picture" />
        </div>

        <section class="about-intro">
            <div class="about-intro-card">
                <p>
                    Hi, I'm <strong>Alina</strong>. I lead Marketing &amp; Growth at
                    <a href="https://piwi.ai" target="_blank" rel="noreferrer">Piwi.AI</a>,
                    where we're building AI-powered tools that help businesses work smarter
                    with their documents and data.
                </p>
                <p>
                    I'm passionate about the intersection of <strong>technology and storytelling</strong>.
                    I believe that great marketing isn't about shouting the loudest. It's about
                    understanding your audience, creating genuine value, and building connections
                    that last.
                </p>
                <p>
                    Before joining Piwi.AI, I built my skills across content creation, brand strategy,
                    and social media management for businesses of all sizes. I've seen firsthand
                    how the right content strategy can transform a small business's visibility
                    and growth.
                </p>
            </div>
        </section>

        <section class="about-skills">
            <h2>What I'm Into</h2>
            <div class="skills-cards">
                <div class="skill-card">
                    <h3>AI in Marketing</h3>
                    <p>Exploring how AI tools can make marketers more creative and efficient, not replace them.</p>
                </div>
                <div class="skill-card">
                    <h3>Content Strategy</h3>
                    <p>Building frameworks that help busy business owners create content consistently.</p>
                </div>
                <div class="skill-card">
                    <h3>Social Media</h3>
                    <p>Platform strategy, community building, and authentic engagement.</p>
                </div>
                <div class="skill-card">
                    <h3>Product Hunt &amp; Launches</h3>
                    <p>The strategy and community behind launching products that get noticed.</p>
                </div>
                <div class="skill-card">
                    <h3>Small Business Growth</h3>
                    <p>Practical, no-fluff advice for businesses without a marketing department.</p>
                </div>
            </div>
        </section>

        <section class="about-contact">
            <h2>Let's Connect</h2>
            <p class="contact-sub">
                I love hearing from fellow marketers, small business owners, and anyone
                curious about AI in marketing. Don't be a stranger!
            </p>
            <div class="contact-links">
                <a href="https://www.linkedin.com/in/alina-anitei/" class="btn btn-primary" target="_blank" rel="noreferrer">LinkedIn</a>
                <a href="https://github.com/AniteiAlina" class="btn btn-outline" target="_blank" rel="noreferrer">GitHub</a>
                <a href="https://piwi.ai" class="btn btn-outline" target="_blank" rel="noreferrer">Piwi.AI</a>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
.about-page h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin-bottom: 1.5rem;
    position: relative;
    display: inline-block;
    padding-bottom: 0.4rem;
}

.about-page h1::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 2px;
}

.about-profile {
    display: flex;
    justify-content: center;
    margin-bottom: 1.75rem;
}

.profile-picture {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    object-fit: cover;
}

.about-intro {
    margin-bottom: 2rem;
}

.about-intro-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.5rem 1.75rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.2);
}

.about-intro p {
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
    font-size: 1rem;
}

.about-intro p:last-child {
    margin-bottom: 0;
}

.about-intro strong {
    color: var(--text);
}

.about-skills {
    margin-bottom: 2rem;
}

.about-skills h2,
.about-contact h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    position: relative;
    display: inline-block;
    padding-bottom: 0.35rem;
}

.about-skills h2::after,
.about-contact h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 2px;
}

.skills-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    transition: background var(--transition), transform var(--transition);
}

.skill-card:hover {
    background: var(--bg-card-hover);
    transform: translateX(3px);
}

.skill-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.3rem;
}

.skill-card p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
}

.about-contact {
    margin-bottom: 1rem;
}

.contact-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    line-height: 1.6;
}

.contact-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}
</style>
